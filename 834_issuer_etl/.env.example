# Processing mode: local | ftp | sftp
PROCESSING_MODE=local

# Clean all outputs before each run (data, reports, extracted, assets)
CLEAN_ON_START=true

# Paths (relative to project root unless absolute)
SOURCE_DATA_PATH=source_data
EXTRACTED_PATH=extracted
DATABASE_PATH=data/issuer_834.db
REPORTS_PATH=reports
ASSETS_PATH=assets
LOGS_PATH=logs

# Optional filters — comma-separated, independent (empty = ALL)
# Examples:
#   YEAR_FILTER=2025
#   MONTH_FILTER=03,04,05,06
#   ISSUER_FILTER=13535,15105
ISSUER_FILTER=
YEAR_FILTER=
MONTH_FILTER=

# Reference row counts for validation (issuer=expected_count, comma-separated)
# Example: Sigma=16464,86637=22
REFERENCE_ROW_COUNTS=

# User fee rate (3.25%)
USER_FEE_RATE=0.0325

# Cancellation window in days
CANCELLATION_WINDOW_DAYS=90

# --- FTP (dummy — not used in local mode) ---
FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USERNAME=dummy_user
FTP_PASSWORD=dummy_password
FTP_REMOTE_PATH=/incoming/834

# --- SFTP (set PROCESSING_MODE=sftp to enable) ---
# Remote: SFTP_ROOT/{issuer}/{year}/{month}/** (recursive, unlimited depth)
# Valid:  from_{issuer}_GA_834_INDV_*.xml | *.xml.gz | *.xml.xz
# Local:  source_data/{issuer}/{year}/{month}/*.xml  (flattened, no subfolders)
SFTP_HOST=sftp.example.com
SFTP_PORT=22
SFTP_USERNAME=dummy_user
SFTP_PASSWORD=dummy_password
SFTP_REMOTE_PATH=/archive/in/good/834

# SFTP audit-only mode (scan without downloading; uses same filters as above)
SFTP_AUDIT_ONLY=false

# Re-download even when local .xml exists (default: skip existing)
FORCE_DOWNLOAD=false

# Keep .xml.gz / .xml.xz copies alongside decompressed .xml
KEEP_COMPRESSED=false
